<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Indoor Phone Tracker"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/deviceIdText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="12sp"
            android:textIsSelectable="true" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="20dp"
            android:background="#DDDDDD" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Live tracking"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Starts continuous scanning and uploads readings for the web dashboard to estimate your position. Updates roughly every 20-30 seconds (Android limits WiFi scan frequency)."
            android:textSize="13sp" />

        <Button
            android:id="@+id/startLiveButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Start live scanning" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="20dp"
            android:background="#DDDDDD" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Record a fingerprint"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="On the web dashboard, tap your current spot on the floor plan — it will show you an x and y value. Enter them here, along with a label, then tap Record while standing at that exact spot."
            android:textSize="13sp" />

        <EditText
            android:id="@+id/labelInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Label (e.g. Kitchen corner)" />

        <EditText
            android:id="@+id/xInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="x (from dashboard, e.g. 0.42)"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/yInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="y (from dashboard, e.g. 0.61)"
            android:inputType="numberDecimal" />

        <Button
            android:id="@+id/recordFingerprintButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Record fingerprint here" />

    </LinearLayout>
</ScrollView>
